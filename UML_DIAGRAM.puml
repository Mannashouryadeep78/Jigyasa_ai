' ─── Contexts ───
package "src/contexts/" {
  class AuthContext <<Context + Provider>> {
    - user : User | null
    - session : Session | null
    --
    + signUp(email, password, name) : Promise
    + signIn(email, password) : Promise
    + signInWithGoogle() : Promise
    + verifyOtp(email, token) : Promise
    + signOut() : Promise
    --
    uses: supabase.auth.*
  }
}

' ─── API / Lib ───
package "src/api/ + src/lib/" {
  class SupabaseJSClient <<singleton>> {
    + createClient(VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY)
    --
    + auth.signUp / signIn / signOut
    + auth.refreshSession()
    + from('sessions').select()
    + auth.onAuthStateChange()
  }

  class ApiClient <<axios singleton>> {
    - baseURL : VITE_API_URL | 'http://localhost:8000'
    - interceptors.request : inject Bearer token
    - interceptors.response : handle 401 + token refresh queue
    --
    + createSession(userId, name, file?, mode?) : Promise<{session_id, message}>
    + respond(sessionId, message) : Promise<{message, status}>
    + getReport(sessionId) : Promise<Assessment>
    + getSession(sessionId) : Promise<{name, history, status}>
    + discontinueSession(sessionId) : Promise
    + generateTTS(text) : Promise<Blob | null>
    + generatePrepQuestions(file) : Promise<{qa_pairs[]}>
    + generateAnalyticsGuidance(history) : Promise<{overview, action_items[]}>
    + getAnalyticsBenchmark() : Promise<{benchmark: dict}>
    + checkATS(file) : Promise<ATSReport>
    + transcribeAudio(blob) : Promise<{transcript: str}>
  }
}

' ─── Custom Hooks ───
package "src/hooks/" {
  class useSpeechRecognition <<Hook>> {
    Params: { onTranscriptSubmit: (text: str) => void }
    --
    - recognitionRef : SpeechRecognition
    - mediaRecorderRef : MediaRecorder
    - accumulatedRef : string
    - silenceTimer : NodeJS.Timeout
    - isMobileDevice : boolean
    --
    Returns:
    + isSupported : boolean
    + isListening : boolean
    + transcript : string
    + startListening() : void
    + stopListening(submit?: boolean) : void
    + toggleListening() : void
    --
    Dual-stream: browser STT for live preview
                 Whisper (via /transcribe) for accuracy
    Mobile: continuous=true (no mic flicker)
    Desktop: continuous=false (standard)
    Auto-submit: 3s silence timer
    Max duration: 120s
  }

  class useTTS <<Hook>> {
    Returns:
    + speak(text: str, onFinish?: () => void) : void
    + stop() : void
    + isSpeaking : boolean
    --
    - utteranceQueue : SpeechSynthesisUtterance[]
    - isAndroid : boolean
    --
    Voice priority: Edge Online Neural
                    > Chrome Google US English
                    > Standard English
    Android rate: 1.15x (compensates slow engine)
    Sentence-split: chunks >200 chars (Chrome bug fix)
  }
}

' ─── Entry / Router ───
package "src/ (Entry + Router)" {
  class Main <<entry>> {
    + ReactDOM.createRoot(#root)
    + render(<AuthProvider><App /></AuthProvider>)
  }

  class App <<Router Component>> {
    - user : User (from AuthContext)
    - publicPhase : 'landing'|'auth'|'prep'
    - phase : 'dashboard'|'upload'|'welcome'|
              'interview'|'report'|
              'round_transition'|'exam_result'
    - session : string (session_id)
    - candidateName : string
    - resumeFile : File | null
    - interviewMode : 'hr'|'technical'|'gd'|'tutor'
    - initialMessage : string
    - initialHistory : Message[]
    - sessionType : 'practice'|'exam'
    - examRound : 0 | 1 | 2
    - examScores : Assessment[]
    - lastRoundScore : number
    - isInitializing : boolean
    --
    + handleStartNew(type: 'practice'|'exam') : void
    + handleUpload(file: File, mode: str) : void
    + handleStartInterview() : Promise<void>
    + handleContinue(sessionId: str) : Promise<void>
    + handleFinish() : Promise<void>
    + handleProceedNextRound() : void
  }
}

' ─── Components ───
package "src/components/" {

  class LandingPage <<Component>> {
    Props: onGoToAuth(mode: str)
    --
    + Hero section with animated headline
    + 3 Feature cards
    + Resume-to-Prep banner (public)
    + Embedded ATSChecker (public)
    + How-it-works steps
    + User menu (if authenticated)
  }

  class Dashboard <<Component>> {
    Props: onStartNew(type), onViewReport(id), onContinue(id)
    --
    - sessions : Session[]
    - activeTab : 'completed'|'active'|'discontinued'
    - activeView : 'list'|'analytics'|'prep'|'ats'|'help'
    --
    + Tab filtering
    + Session cards (status, name, date, score)
    + Mode choice modal (Practice vs Exam)
    + Renders sub-views: AnalyticsView, InterviewPrepTool, ATSChecker
    --
    Reads: supabase.from('sessions').select()
           filtered by user_id
  }

  class InterviewRoom <<Component>> {
    Props:
    + sessionId : string
    + candidateName : string
    + initialMessage : string
    + initialHistory? : Message[]
    + onFinish : () => void
    + onCancel : () => void
    --
    - history : {id, role, content}[]
    - typedAnswer : string
    - isProcessing : boolean
    - isProcessingRef : MutableRefObject<bool>
    - isMountedRef : MutableRefObject<bool>
    - blankCountRef : MutableRefObject<int>
    - chatEndRef : MutableRefObject<HTMLDivElement>
    --
    + handleTranscriptSubmit(text: str) : Promise
    + handleManualSubmit() : void
    + handleCancel() : void
    --
    Auto-scroll: useEffect after useSpeechRecognition decl.
    TTS: auto-plays each AI response
    Voice flow: STT → submit → api.respond() → TTS
  }

  class AssessmentReport <<Component>> {
    Props: sessionId: string
    --
    - assessment : Assessment | null
    - loading : boolean
    --
    + Polls api.getReport() every 2s (max 2min)
    + Score grid (1–5 per dimension with anchors)
    + Evidence quotes per dimension
    + Wrong answers with LLM analysis
    + @media print CSS for PDF export
  }

  class AnalyticsView <<Component>> {
    Props: sessions: Session[], onBack: () => void
    --
    - chartData : ChartPoint[]
    - benchmark : {[key: str]: float}
    - guidance : {overview: str, action_items: str[]}
    - loadingGuidance : boolean
    - guidanceError : boolean
    - sessionSummaries : Summary[]
    - isExpanded : boolean
    --
    + fetchGuidance(summaries: Summary[]) : Promise
    + Expand modal (AnimatePresence)
    + BarChart: "Your Avg" vs "Best in Class"
    + AI executive coach report
  }

  class AnalyticsContent <<Sub-Component>> {
    Props: isExpanded, chartData, loadingGuidance,
           guidanceError, guidance, sessionSummaries,
           fetchGuidance, setLoadingGuidance
    --
    - chartContainerRef : MutableRefObject<HTMLDivElement>
    - chartDims : {width: int, height: int}
    --
    + useLayoutEffect: ResizeObserver for explicit dims
    + Recharts BarChart (explicit pixel w/h, no ResponsiveContainer)
    + Guidance panel (overview + action_items)
  }

  class InterviewPrepTool <<Component>> {
    + Resume upload (PDF)
    + api.generatePrepQuestions(file)
    + Displays 20 Q&A pairs
    + @media print PDF export
  }

  class ATSChecker <<Component>> {
    + Resume upload (PDF)
    + api.checkATS(file)
    + ATS score vs Workday, Greenhouse, Lever, iCIMS
    + Keyword gaps + formatting issues
  }

  class ResumeUpload <<Component>> {
    Props: onUpload(file, mode), onBack()
    --
    + File picker (PDF only)
    + Interview mode selector
      (hr | technical | gd | tutor)
  }

  class WelcomeScreen <<Component>> {
    Props: candidateName, onStart(), onBack()
    --
    + Name confirmation
    + Start Interview button
  }

  class LoginScreen <<Component>> {
    Props: onAuth()
    --
    + Email / password form
    + Google OAuth button
    + OTP verification
  }

  class RoundTransition <<Component>> {
    Props: round: int, score: float, onNext()
    --
    + Shows round N score
    + Preview of next round
  }

  class ExamResultScreen <<Component>> {
    Props: scores: Assessment[], onBack()
    --
    + 3-round final scores
    + Side-by-side comparison
  }

  class WaveformVisualizer <<Component>> {
    Props: isActive: boolean
    --
    + Animated bar waveform
    + Responds to isListening / isSpeaking
  }
}

