@startuml 4_Database_Schema

title Jigyasa.ai — Supabase Database Schema

skinparam backgroundColor #0d0d1a
skinparam entityBackgroundColor #1e1d24
skinparam entityBorderColor #b45309
skinparam entityHeaderBackgroundColor #2a1f0a
skinparam entityFontColor #f5cca8
skinparam entityAttributeFontColor #ffffff90
skinparam ArrowColor #b45309

entity "auth.users\n<Supabase Managed>" as USERS {
  * id : UUID <<PK>>
  --
  email : text
  created_at : timestamp
  user_metadata : jsonb
}

entity "public.sessions" as SESSIONS {
  * id : UUID <<PK>>
  --
  name : text
  user_id : UUID <<FK → auth.users>>
  status : text
  created_at : timestamptz
  state_json : JSONB
}

note right of SESSIONS
  status values:
    'active' | 'finished' | 'discontinued'

  state_json (crash recovery):
    serialized LangGraph state —
    messages, phase, metadata
    written after every turn
end note

entity "public.assessments" as ASSESSMENTS {
  * id : UUID <<PK>>
  --
  session_id : UUID <<FK → sessions>>
  scores_json : JSONB
  quotes_json : JSONB
  created_at : timestamptz
}

note right of ASSESSMENTS
  scores_json example (HR mode):
  {
    "communication_clarity": 4,
    "cultural_fit_values": 3,
    "problem_solving_attitude": 5,
    "confidence_presence": 4,
    "english_fluency": 4
  }

  quotes_json example:
  {
    "communication_clarity": "exact quote..."
  }
end note

USERS ||--o{ SESSIONS : "1 user → many sessions"
SESSIONS ||--o| ASSESSMENTS : "1 session → 0-1 assessment"

@enduml


