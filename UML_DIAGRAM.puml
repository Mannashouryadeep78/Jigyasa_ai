  note right of GroqClient
    get_llm():      llama-3.3-70b-versatile, temp=0.7, timeout=25s
    get_json_llm(): llama-3.3-70b-versatile, temp=0.1, timeout=40s, json_mode
    transcribe_audio(): whisper-large-v3
  end note
}

' ─── services/supabase_client.py ───
