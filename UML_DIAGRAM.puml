' ║  7. LANGGRAPH STATE-MACHINE DIAGRAM                      ║
' ╚══════════════════════════════════════════════════════════╝

@startuml 7_LangGraph_StateMachine

title Jigyasa.ai — LangGraph Interview State Machine

skinparam backgroundColor #0d0d1a
skinparam stateBackgroundColor #1e1d24
skinparam stateBorderColor #b45309
skinparam stateHeaderBackgroundColor #2a1f0a
skinparam stateFontColor #f5cca8
skinparam ArrowColor #b45309
skinparam ArrowFontColor #f5cca8
skinparam noteFontColor #ffffff80
skinparam noteBackgroundColor #1e1d24
skinparam noteBorderColor #b45309

[*] --> ROUTER : invoke() called

state ROUTER <<choice>>
ROUTER --> GREETER : no messages in state
ROUTER --> QUESTION_SELECTOR : phase == "greeting"
ROUTER --> FOLLOWUP_DECIDER : phase in [question, followup]
ROUTER --> [*] : phase in [closer, finished]

state "greeter()\nPhase → greeting" as GREETER {
  GREETER : Mode-specific greeting
  GREETER : Alex / Jordan / Morgan / Prof. Maria
}

GREETER --> QUESTION_SELECTOR : next turn

state "question_selector()\nPhase → question" as QUESTION_SELECTOR {
  QUESTION_SELECTOR : System prompt + last 6 messages
  QUESTION_SELECTOR : LLM generates next question
  QUESTION_SELECTOR : followup_count = 0
}

state FOLLOWUP_DECIDER <<choice>>

QUESTION_SELECTOR --> FOLLOWUP_DECIDER : next human turn arrives

note right of FOLLOWUP_DECIDER
  decide_followup() logic:
  1. turn_count >= 5           → CLOSER
  2. answer < 12 chars         → EDGE_CASE
     AND followup_count == 0
  3. followup_count >= 1       → QUESTION_SELECTOR
  4. else                      → RESPONDER
end note

FOLLOWUP_DECIDER --> CLOSER : turn_count >= 5
FOLLOWUP_DECIDER --> EDGE_CASE_HANDLER : short answer, fc==0
FOLLOWUP_DECIDER --> RESPONDER : else
FOLLOWUP_DECIDER --> QUESTION_SELECTOR : followup_count >= 1

state "edge_case_handler()\nPhase → followup" as EDGE_CASE_HANDLER {
  EDGE_CASE_HANDLER : Prompts candidate to elaborate
}

state "responder()\nPhase → followup" as RESPONDER {
  RESPONDER : LLM probes deeper on answer
  RESPONDER : followup_count + 1
}

EDGE_CASE_HANDLER --> FOLLOWUP_DECIDER : next human turn
RESPONDER --> FOLLOWUP_DECIDER : next human turn

state "closer()\nPhase → closer" as CLOSER {
  CLOSER : Mode-specific closing message
  CLOSER : Thank + transition phrase
}

CLOSER --> ASSESSOR : next turn

state "assessor()\nPhase → finished" as ASSESSOR {
  ASSESSOR : format_transcript(messages)
  ASSESSOR : get_json_llm() + rubric prompt
  ASSESSOR : Parse JSON: {scores, quotes, wrong_answers}
  ASSESSOR : save_assessment() → Supabase
  ASSESSOR : update_session_status("finished")
}

ASSESSOR --> [*] : session complete

@enduml
