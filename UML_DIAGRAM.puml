' ─── graph/state.py ───
package "graph/state.py" {
  class InterviewState <<TypedDict>> {
    + session_id : str
    + candidate_name : str
    + resume_text : str
    + interview_mode : str
    + messages : Annotated[List[BaseMessage], operator.add]
    + current_phase : str
    + questions_asked : List[str]
    + answers_given : List[str]
    + followup_count : int
    + assessment : dict
    + turn_count : int
  }
  note right of InterviewState
    current_phase values:
    "start" | "greeting" | "question"
    | "followup" | "closer" | "finished"

    interview_mode values:
    "hr" | "technical" | "gd" | "tutor"
  end note
}

' ─── graph/nodes.py ───
package "graph/nodes.py" {
  class GraphNodes <<module>> {
    + greeter(state: InterviewState) : dict
    + question_selector(state: InterviewState) : dict
    + responder(state: InterviewState) : dict
    + followup_decider(state: InterviewState) : dict
    + edge_case_handler(state: InterviewState) : dict
    + closer(state: InterviewState) : dict
    + assessor(state: InterviewState) : dict
  }
  note bottom of GraphNodes
    greeter        → phase: "greeting"
    question_selector → phase: "question"
    responder      → followup_count + 1
    assessor       → scores JSON from LLM
  end note
}

' ─── graph/edges.py ───
package "graph/edges.py" {
  class GraphEdges <<module>> {
    + route_from_start(state: InterviewState) : str
    + decide_followup(state: InterviewState) : str
  }
  note right of GraphEdges
    route_from_start:
      no messages        → "greeter"
      phase=="greeting"  → "question_selector"
      phase in [question,followup] → "followup_decider"
      phase in [closer,finished]   → END

    decide_followup:
      turn_count >= 5               → "closer"
      answer < 12 chars, fc==0      → "edge_case_handler"
      followup_count >= 1           → "question_selector"
      else                          → "responder"
  end note
}

' ─── graph/interview_graph.py ───
package "graph/interview_graph.py" {
  class InterviewGraph <<StateGraph>> {
    + add_node(name, fn)
    + add_edge(from, to)
    + add_conditional_edges(from, router, mapping)
    + set_entry_point("router")
    + compile(checkpointer: MemorySaver)
    --
    + invoke(state: InterviewState, config: dict) : InterviewState
    + stream(state: InterviewState, config: dict) : Iterable
    + update_state(config: dict, values: dict) : None
    + get_state(config: dict) : StateSnapshot
  }
}

' ─── prompts/system.py ───
package "prompts/system.py" {
  class PersonaPrompts <<module>> {
    + HR_PROMPT : str
    + TECHNICAL_PROMPT : str
    + GD_PROMPT : str
    + TUTOR_PROMPT : str
    --
    + get_system_prompt(mode: str) : str
  }
  note right of PersonaPrompts
    HR_PROMPT      → "Alex"  (Career, values, conflict)
    TECHNICAL_PROMPT → "Jordan" (Resume-specific domain)
    GD_PROMPT      → "Morgan" (Education policy debate)
    TUTOR_PROMPT   → "Prof. Maria" (Pedagogical scenarios)
  end note
}

' ─── prompts/rubric.py ───
package "prompts/rubric.py" {
  class RubricPrompts <<module>> {
    + HR_RUBRIC : str
    + TECHNICAL_RUBRIC : str
    + GD_RUBRIC : str
    + TUTOR_RUBRIC : str
    --
    + get_rubric_prompt(mode: str) : str
  }
  note right of RubricPrompts
    Each rubric evaluates 5 dimensions on 1-5 scale.
    Output JSON: {
      scores: {key: score},
      quotes: {key: evidence},
      wrong_answers: [{question, answer, reason}],
      overall_score: float
    }
  end note
}

' ─── services/groq_client.py ───
package "services/groq_client.py" {
  class GroqClient <<module>> {
    + GROQ_API_KEY : str
    --
    + get_llm() : ChatGroq
    + get_json_llm() : ChatGroq
    + transcribe_audio(file_path: str) : str
