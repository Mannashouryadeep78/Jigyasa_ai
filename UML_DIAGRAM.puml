participant "nodes.py" as ND
participant "groq_client.py\n(Groq LLM)" as LLM
participant "supabase_client.py" as DB
database "Supabase" as SUPA

== Session Creation ==
C -> IR : click "Start Interview"
IR -> API : createSession(userId, name, file, mode)
API -> BE : POST /session (multipart + JWT)
BE -> BE : _sanitize_name()\n_validate_pdf()\n_verify_session_owner()
BE -> DB : log_session(session_id, name, user_id)
DB -> SUPA : POST /rest/v1/sessions
BE -> GR : invoke(initial_state, config)
GR -> ND : greeter(state)
ND -> LLM : ChatGroq.invoke([SystemMsg, HumanMsg])
LLM --> ND : greeting text
ND --> GR : {messages: [AIMsg], phase: "greeting"}
GR -> DB : save_session_state(session_id, state)
DB -> SUPA : PATCH /rest/v1/sessions (state_json)
BE --> API : {session_id, message: greeting}
API --> IR : greeting message
IR -> TTS : speak(greeting)
TTS --> C : AI greeting audio

== Question-Answer Turn Loop ==
loop until turn_count >= 5 or phase == "finished"

  C -> IR : starts speaking
  IR -> STT : startListening()
  STT --> IR : transcript (live preview, browser STT)

  note over STT
    MediaRecorder also capturing
    raw audio in parallel
  end note

  STT -> STT : 3s silence detected
  STT -> API : transcribeAudio(audioBlob)
  API -> BE : POST /transcribe (audio blob)
  BE -> LLM : whisper-large-v3.transcribe()
  LLM --> BE : high-accuracy transcript
  BE --> API : {transcript}
  API --> STT : Whisper text replaces browser text

  STT -> IR : onTranscriptSubmit(finalText)
  IR -> API : respond(session_id, finalText)
  API -> BE : POST /respond (JWT + body)
  BE -> BE : get_session_lock(session_id) — concurrency guard
  BE -> GR : invoke({messages: [HumanMsg]}, config)

  GR -> ND : route_from_start(state)
  note over GR, ND
    Routing:
    phase=="greeting" → question_selector
    phase=="question" → followup_decider → decide_followup()
  end note

  ND -> LLM : ChatGroq.invoke([SystemMsg, ...last_6_messages])
  LLM --> ND : interviewer response
  ND --> GR : {messages: [AIMsg], phase: "question"}

  GR -> DB : save_session_state()
  DB -> SUPA : PATCH sessions

  BE --> API : {message: AI_response, status: "question"}
  API --> IR : response message
  IR -> TTS : speak(AI_response)
  TTS --> C : AI audio playback
  IR -> STT : startListening() [auto-restart]

end

== Assessment Phase ==
BE -> GR : phase transitions to "closer" then "assessor"
GR -> ND : assessor(state)
ND -> ND : format_transcript(messages)
ND -> LLM : get_json_llm().invoke([rubric_prompt, transcript])
LLM --> ND : JSON {scores, quotes, wrong_answers, overall_score}
ND -> DB : save_assessment(session_id, scores, quotes)
DB -> SUPA : POST /rest/v1/assessments
ND -> DB : update_session_status(session_id, "finished")
BE --> API : {message: closing, status: "finished"}
API --> IR : status == "finished"
IR -> IR : onFinish() callback
IR --> C : navigates to AssessmentReport

== Report Retrieval ==
C -> IR : (in AssessmentReport)
IR -> API : getReport(session_id) [polls every 2s]
API -> BE : GET /report/{session_id}
BE -> DB : read assessments table
DB -> SUPA : GET /rest/v1/assessments?session_id=...
SUPA --> DB : assessment row
DB --> BE : {scores_json, quotes_json}
BE --> API : assessment data
API --> IR : render score cards

@enduml


