' ║  6. AUTHENTICATION — SEQUENCE DIAGRAM                    ║
' ╚══════════════════════════════════════════════════════════╝

@startuml 6_Auth_Sequence

title Jigyasa.ai — Authentication & Token Lifecycle (Sequence)

skinparam backgroundColor #0d0d1a
skinparam participantBackgroundColor #1e1d24
skinparam participantBorderColor #b45309
skinparam participantFontColor #f5cca8
skinparam sequenceArrowColor #b45309
skinparam sequenceArrowFontColor #f5cca8
skinparam noteFontColor #ffffff80
skinparam noteBackgroundColor #1e1d24

actor User as U
participant "LoginScreen.jsx" as LS
participant "AuthContext.jsx" as AC
participant "supabase.js\n(JS client)" as SB_FE
participant "api/client.js\n(axios interceptors)" as AXIOS
participant "main.py\nget_current_user()" as BE
database "Supabase Auth\n(JWT Issuer)" as SUPA_AUTH

== Sign In ==
U -> LS : submits email + password
LS -> AC : signIn({email, password})
AC -> SB_FE : supabase.auth.signInWithPassword()
SB_FE -> SUPA_AUTH : POST /auth/v1/token
SUPA_AUTH --> SB_FE : {access_token (JWT), refresh_token, user}
SB_FE -> SB_FE : store in localStorage\n"sb-<ref>-auth-token"
SB_FE --> AC : session
AC --> LS : user set in context
LS -> LS : navigate to dashboard

== Authenticated API Request ==
U -> AXIOS : any api.* call (e.g., createSession)
AXIOS -> AXIOS : request interceptor:\nread localStorage → extract access_token
AXIOS -> BE : HTTP request + "Authorization: Bearer <JWT>"
BE -> BE : get_current_user(authorization)
BE -> SUPA_AUTH : verify JWT signature + claims
SUPA_AUTH --> BE : {user_id, email, ...}
BE --> AXIOS : 200 response data

== Token Expiry + Auto-Refresh ==
AXIOS -> BE : request with expired JWT
BE --> AXIOS : 401 Unauthorized
AXIOS -> AXIOS : response interceptor:\n_retry not set → start refresh
AXIOS -> SB_FE : supabase.auth.refreshSession()
SB_FE -> SUPA_AUTH : POST /auth/v1/token (refresh_token)
SUPA_AUTH --> SB_FE : new {access_token, refresh_token}
SB_FE --> AXIOS : new token
note over AXIOS
  If multiple requests hit 401 simultaneously,
  they queue behind the single refresh call
  (refreshQueue pattern)
end note
AXIOS -> BE : retry original request + new token
BE --> AXIOS : 200 OK

== Token Refresh Failure ==
AXIOS -> SB_FE : supabase.auth.refreshSession()
SB_FE -> SUPA_AUTH : expired refresh token
SUPA_AUTH --> SB_FE : error
SB_FE --> AXIOS : refreshError
AXIOS -> SB_FE : signOut()
AXIOS -> AXIOS : window.location.href = '/'
note right: Hard redirect clears all local state

@enduml


